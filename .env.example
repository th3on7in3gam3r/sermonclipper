# Local environment variables for SermonClipper

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Cloudflare R2 configuration
CF_ACCOUNT_ID=<your-cloudflare-account-id>
R2_BUCKET=sermon-clipper
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
# Optional: hardcode the R2 endpoint if needed
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Optional YouTube download cookies support
# Use a browser cookies file (exported from Chrome/Firefox) to avoid YouTube bot checks.
YTDLP_COOKIES_PATH=/path/to/youtube_cookies.txt
# Or use yt-dlp browser cookie extraction if available on the host.
# Supported values: chrome, chromium, firefox
YTDLP_COOKIES_BROWSER=chrome
